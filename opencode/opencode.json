{
  "$schema": "https://opencode.ai/config.json",
  "keybinds": {
    "input_newline": "shift+return,ctrl+return,alt+return"
  },
  "mcp": {
    "next-devtools": {
      "enabled": false,
      "type": "local",
      "command": ["yarn", "dlx", "next-devtools-mcp"]
    },
    "linear": {
      "enabled": false,
      "type": "local",
      "command": ["yarn", "dlx", "mcp-remote", "https://mcp.linear.app/mcp"]
    },
    "mantine": {
      "enabled": false,
      "type": "local",
      "command": ["yarn", "dlx", "@mantine/mcp-server"]
    }
  }
}
